---
import config from 'virtual:starlight/user-config';

import LanguageSelect from 'virtual:starlight/components/LanguageSelect';
import Search from 'virtual:starlight/components/Search';
import SiteTitle from 'virtual:starlight/components/SiteTitle';
import SocialIcons from 'virtual:starlight/components/SocialIcons';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';

const shouldRenderSearch =
	config.pagefind || config.components.Search !== '@astrojs/starlight/components/Search.astro';

const currentPath = Astro.url.pathname;

const navItems = [
	{ label: 'Get Started', href: '/get-started/overview/' },
	{ label: 'Concepts', href: '/concepts/what-is-rearch/' },
	{ label: 'Guides', href: '/guides/conversations/' },
	{ label: 'Deploy & Operate', href: '/deploy/self-hosting/' },
	{ label: 'Reference', href: '/reference/configuration/' },
	{ label: 'Learning Hub', href: '/learning/' },
	{ label: 'Contributing', href: 'https://github.com/rearch-engineer/rearch' },
];

function isActive(href: string): boolean {
	const section = href.split('/').filter(Boolean)[0];
	const currentSection = currentPath.split('/').filter(Boolean)[0];
	return section === currentSection;
}
---

<div class="rearch-header">
	{/* ── Row 1: Logo | Search | Right actions ── */}
	<div class="rearch-header-top">
		<div class="rearch-header-left">
			<a href="/" class="header-brand">
				{/* MUI ForumIcon SVG — same icon used in the ReArch app */}
				<svg class="header-brand-icon" viewBox="0 0 24 24" fill="#DB4F15" width="26" height="26" aria-hidden="true">
					<path d="M21 6h-2v9H6v2c0 .55.45 1 1 1h11l4 4V7c0-.55-.45-1-1-1m-4 6V3c0-.55-.45-1-1-1H3c-.55 0-1 .45-1 1v14l4-4h10c.55 0 1-.45 1-1"/>
				</svg>
				<span class="header-brand-name">ReArch</span>
				<span class="header-brand-docs">DOCS</span>
			</a>
		</div>
		<div class="rearch-header-center sl-flex print:hidden">
			{shouldRenderSearch && <Search />}
		</div>
		<div class="rearch-header-right sl-hidden md:sl-flex print:hidden">
			<div class="sl-flex social-icons">
				<SocialIcons />
			</div>
			<ThemeSelect />
			<LanguageSelect />
		</div>
	</div>

	{/* ── Row 2: Navigation links ── */}
	<nav class="rearch-header-nav sl-hidden md:sl-flex print:hidden" aria-label="Main">
		<div class="rearch-header-nav-links">
			{navItems.map((item) => (
				<a
					class:list={['rearch-nav-link', { active: isActive(item.href) }]}
					href={item.href}
				>
					{item.label}
				</a>
			))}
		</div>
	</nav>
</div>

<style>
	/* ── Two-row header ── */
	.rearch-header {
		display: flex;
		flex-direction: column;
		height: 100%;
		justify-content: center;
		gap: 0;
	}

	/* ── Row 1 ── */
	.rearch-header-top {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.5rem 0;
	}

	.rearch-header-left {
		display: flex;
		align-items: center;
		min-width: 0;
		overflow: clip;
		flex-shrink: 0;
	}

	/* Brand logo — matches the ReArch app's ForumIcon + "ReArch" pattern */
	.header-brand {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		text-decoration: none;
		white-space: nowrap;
	}

	.header-brand-icon {
		flex-shrink: 0;
	}

	.header-brand-name {
		font-family: 'Poppins', sans-serif;
		font-weight: 700;
		font-size: 1.4rem;
		color: var(--sl-color-white);
	}

	:root[data-theme='light'] .header-brand-name {
		color: #000;
	}

	.header-brand-docs {
		font-family: 'Poppins', sans-serif;
		font-weight: 600;
		font-size: 1.4rem;
		color: var(--sl-color-gray-3);
		margin-left: 0.1rem;
	}

	.rearch-header-center {
		display: flex;
		align-items: center;
		justify-content: center;
		flex: 1 1 auto;
		min-width: 0;
	}

	.rearch-header-right {
		display: flex;
		align-items: center;
		gap: 1rem;
		flex-shrink: 0;
	}

	.social-icons {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	/* ── Row 2: nav links ── */
	.rearch-header-nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0;
	}

	.rearch-header-nav-links {
		display: flex;
		align-items: center;
		gap: 0;
	}

	.rearch-nav-link {
		display: inline-flex;
		align-items: center;
		padding: 0.5rem 0.85rem;
		font-size: 0.8125rem;
		font-weight: 500;
		color: var(--sl-color-gray-2);
		text-decoration: none;
		white-space: nowrap;
		border-bottom: 2px solid transparent;
		margin-bottom: -1px;
		transition: color 0.15s ease, border-color 0.15s ease;
	}

	.rearch-nav-link:first-child {
		padding-left: 0;
	}

	.rearch-nav-link:hover {
		color: var(--sl-color-white);
	}

	.rearch-nav-link.active {
		color: var(--sl-color-white);
		border-bottom-color: var(--sl-color-accent);
	}

	/* Hide row 2 on small screens — sidebar takes over */
	@media (max-width: 72rem) {
		.rearch-header-nav {
			display: none;
		}
		.rearch-header-top {
			padding: 0;
		}
	}
</style>
